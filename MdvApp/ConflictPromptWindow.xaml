<ui:FluentWindow x:Class="MdvApp.ConflictPromptWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="File already exists"
                 Width="440" SizeToContent="Height"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="File already exists" />

        <StackPanel Grid.Row="1" Margin="20,8,20,20">
            <ui:TextBlock x:Name="MessageText" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,20" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Overwrite" Appearance="Primary" Margin="0,0,8,0" Click="OnOverwrite" />
                <ui:Button Content="Rename" Margin="0,0,8,0" Click="OnRename" />
                <ui:Button Content="Cancel" Click="OnCancel" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
