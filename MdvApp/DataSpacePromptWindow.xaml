<ui:FluentWindow x:Class="MdvApp.DataSpacePromptWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Set executable"
                 Width="440" SizeToContent="Height"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Set executable" />

        <StackPanel Grid.Row="1" Margin="20,8,20,20">
            <ui:TextBlock Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8"
                          Text="Executable files carry a data-space size (bytes) reserved when the program runs." />
            <ui:TextBlock Text="Data space (bytes):" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
            <ui:NumberBox x:Name="DataSpaceBox" Minimum="0" Maximum="16777215" SmallChange="1024" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <ui:Button Content="Apply" Appearance="Primary" Margin="0,0,8,0" Click="OnApply" />
                <ui:Button Content="Cancel" Click="OnCancel" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
