<Page x:Class="MdvApp.Pages.CartridgePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:conv="clr-namespace:MdvApp.Converters"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="980"
      Title="Cartridge">
    <Page.Resources>
        <conv:FileKindToSymbolConverter x:Key="FileKindToSymbol" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <!-- Executables tint green; everything else uses the theme text colour. -->
        <Style x:Key="FileCellText" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="Executable">
                    <Setter Property="Foreground" Value="#8FE38F" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Wrapper that shows a 1px outline on hover (white in dark mode, near-black in light). -->
        <Style x:Key="HoverOutline" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Margin" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Row style without the selected-row accent pill (which also nudged the
             row content to the right when selected). -->
        <Style x:Key="CartridgeRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="RowBorder" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                <DataGridDetailsPresenter Grid.Row="1"
                                                          Visibility="{TemplateBinding DetailsVisibility}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background"
                                        Value="{DynamicResource ListViewItemBackgroundPointerOver}" />
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background"
                                        Value="{DynamicResource ListViewItemBackgroundPointerOver}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid Margin="24,8,24,24" AllowDrop="True" DragOver="OnFilesDragOver" Drop="OnFilesDrop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" Text="Cartridge" FontTypography="Title" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        <ui:TextBlock Grid.Row="1" x:Name="MediumNameText" FontTypography="Body" Margin="0,2,0,16"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Style="{StaticResource HoverOutline}" Margin="0,0,8,0">
                <ui:Button Content="Import File(s)" Icon="{ui:SymbolIcon DocumentAdd24}" Click="OnImportFile" />
            </Border>
            <Border Style="{StaticResource HoverOutline}" Margin="0,0,8,0">
                <ui:Button Content="Import From ZIP" Icon="{ui:SymbolIcon FolderZip24}" Click="OnImportFromZip" />
            </Border>
            <Border Margin="0,0,8,0" BorderThickness="1" BorderBrush="Transparent" CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <!-- Outline only when hovered AND the Save button is enabled. -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding IsEnabled, ElementName=SaveButton}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="BorderBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ui:Button x:Name="SaveButton" Content="Save" Icon="{ui:SymbolIcon Save24}" Appearance="Primary" Click="OnSave" />
            </Border>
            <Border Style="{StaticResource HoverOutline}" Margin="0,0,8,0">
                <ui:Button Content="Save As…" Icon="{ui:SymbolIcon Save24}" Click="OnSaveAs" />
            </Border>
            <Border Style="{StaticResource HoverOutline}" Margin="0,0,8,0">
                <ui:Button Content="Export to ZIP" Icon="{ui:SymbolIcon FolderZip24}" Click="OnExportToZip" />
            </Border>
            <Border Style="{StaticResource HoverOutline}" Margin="0,0,8,0">
                <ui:Button Content="Extract All" Icon="{ui:SymbolIcon ArrowExportLtr24}" Click="OnExtractAll" />
            </Border>
            <Border Style="{StaticResource HoverOutline}" Margin="0">
                <ui:Button Content="Export Minerva… (experimental)" Icon="{ui:SymbolIcon Warning24}"
                           ToolTip="Save a copy with sector 13 damaged so the Minerva ROM accepts it. Experimental, unverified on hardware."
                           Click="OnExportMinerva" />
            </Border>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <DataGrid x:Name="FilesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="Transparent"
                          BorderThickness="0"
                          Margin="4"
                          SelectionMode="Single"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          SelectionChanged="OnFileSelected"
                          MouseDoubleClick="OnFileActivated"
                          PreviewKeyDown="OnFilesPreviewKeyDown"
                          RowStyle="{StaticResource CartridgeRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:SymbolIcon HorizontalAlignment="Center"
                                                   Symbol="{Binding Type, Converter={StaticResource FileKindToSymbol}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"
                                            ElementStyle="{StaticResource FileCellText}" />
                        <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="140"
                                            ElementStyle="{StaticResource FileCellText}" />
                        <DataGridTextColumn Header="Length (bytes)" Binding="{Binding DataLength}" Width="160"
                                            ElementStyle="{StaticResource FileCellText}" />
                        <DataGridTextColumn Header="Blocks" Binding="{Binding BlockCount}" Width="100"
                                            ElementStyle="{StaticResource FileCellText}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- File detail panel -->
            <Border Grid.Column="1" Margin="16,0,0,0" Padding="16" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <ui:TextBlock x:Name="DetailPlaceholder"
                                  Text="Select a file to see its details."
                                  TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <StackPanel x:Name="DetailContent" Visibility="Collapsed" DataContext="{x:Null}"
                                TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ui:SymbolIcon Grid.Column="0" FontSize="28" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Top" Margin="0,0,10,0"
                                           Symbol="{Binding Type, Converter={StaticResource FileKindToSymbol}}" />

                            <StackPanel Grid.Column="1">
                                <ui:TextBlock Text="{Binding Name}" FontTypography="Subtitle" FontWeight="Bold"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <ui:TextBlock Text="{Binding TypeLabel}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,2"
                                              Visibility="{Binding ShowType, Converter={StaticResource BoolToVisibility}}" />
                                <ui:TextBlock Text="{Binding DataLength, StringFormat='Length: {0:N0} bytes'}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,2" />
                                <ui:TextBlock Text="{Binding DataSpace, StringFormat='Data space: {0:N0} bytes'}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,2"
                                              Visibility="{Binding IsExecutable, Converter={StaticResource BoolToVisibility}}" />
                                <ui:TextBlock Text="{Binding FileNumber, StringFormat='File number: {0}'}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,2" />
                                <ui:TextBlock Text="{Binding BlockCount, StringFormat='Blocks: {0}'}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <ui:TextBlock x:Name="ChecksumText" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,2,0,0" />

                                <Expander Header="QL file header" IsExpanded="False"
                                          Margin="0,16,0,0" Padding="0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          Background="Transparent" BorderThickness="0">
                                    <StackPanel Margin="12,8,4,8">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:TextBlock x:Name="TypeCodeText" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                          VerticalAlignment="Center" />
                                            <ui:SymbolIcon Symbol="Info24" FontSize="14" Margin="6,0,0,0"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"
                                                           Cursor="Help" ToolTipService.ShowDuration="20000">
                                                <ui:SymbolIcon.ToolTip>
                                                    <ToolTip MaxWidth="360">
                                                        <TextBlock TextWrapping="Wrap"
                                                                   Text="QL file type codes:&#10;0 — Data: text, documents and SuperBASIC/SBASIC programs&#10;1 — Executable: compiled machine code (EXEC / EX)&#10;2 — Relocatable: object files (SROFF)&#10;255 — Directory: internal filesystem catalogue" />
                                                    </ToolTip>
                                                </ui:SymbolIcon.ToolTip>
                                            </ui:SymbolIcon>
                                        </StackPanel>
                                        <ui:TextBlock x:Name="HeaderInfoText" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                      TextWrapping="Wrap" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource HoverOutline}">
                            <ui:Button Content="Show on sector map" Icon="{ui:SymbolIcon Grid24}"
                                       HorizontalAlignment="Stretch" Click="OnShowOnSectorMap" />
                        </Border>

                        <ui:TextBlock Text="File operations" FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,16,0,8" />
                        <UniformGrid Columns="2">
                            <Border Style="{StaticResource HoverOutline}">
                                <ui:Button Content="Inspect" Icon="{ui:SymbolIcon Eye24}"
                                           HorizontalAlignment="Stretch" Click="OnInspectFile" />
                            </Border>
                            <Border Style="{StaticResource HoverOutline}">
                                <ui:Button Content="Rename" Icon="{ui:SymbolIcon Rename24}"
                                           HorizontalAlignment="Stretch" Click="OnRenameFile" />
                            </Border>
                            <Border Style="{StaticResource HoverOutline}">
                                <ui:Button Content="Duplicate" Icon="{ui:SymbolIcon DocumentCopy24}"
                                           HorizontalAlignment="Stretch" Click="OnDuplicateFile" />
                            </Border>
                            <Border Style="{StaticResource HoverOutline}">
                                <ui:Button Content="Extract" Icon="{ui:SymbolIcon ArrowExportLtr24}"
                                           HorizontalAlignment="Stretch" Click="OnExtractFile" />
                            </Border>
                            <Border Style="{StaticResource HoverOutline}">
                                <ui:Button x:Name="SetExecButton" Content="Set Exec" Icon="{ui:SymbolIcon AppGeneric24}"
                                           HorizontalAlignment="Stretch" Click="OnSetExecutable" />
                            </Border>
                            <Border Style="{StaticResource HoverOutline}">
                                <ui:Button Content="Delete" Icon="{ui:SymbolIcon Delete24}"
                                           HorizontalAlignment="Stretch" Click="OnDeleteFile" />
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
