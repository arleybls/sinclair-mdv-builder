<Page x:Class="MdvApp.Pages.CartridgePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="980"
      Title="Cartridge">
    <Grid Margin="24,8,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" Text="Cartridge directory" FontTypography="Title" />
        <ui:TextBlock Grid.Row="1" x:Name="MediumNameText" FontTypography="Body" Margin="0,2,0,16"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <ui:Button Content="New" Icon="{ui:SymbolIcon Add24}" Margin="0,0,8,0" Click="OnNotImplemented" />
            <ui:Button Content="Open…" Icon="{ui:SymbolIcon FolderOpen24}" Margin="0,0,8,0" Click="OnOpenCartridge" />
            <ui:Button Content="Import file" Icon="{ui:SymbolIcon DocumentAdd24}" Margin="0,0,8,0" Click="OnNotImplemented" />
            <ui:Button Content="Import ZIP" Icon="{ui:SymbolIcon FolderZip24}" Margin="0,0,8,0" Click="OnNotImplemented" />
            <ui:Button Content="Extract" Icon="{ui:SymbolIcon ArrowExportLtr24}" Margin="0,0,8,0" Click="OnNotImplemented" />
            <ui:Button Content="Remove" Icon="{ui:SymbolIcon Delete24}" Margin="0,0,8,0" Click="OnNotImplemented" />
            <ui:Button Content="Save As…" Icon="{ui:SymbolIcon Save24}" Appearance="Primary" Click="OnSaveAs" />
        </StackPanel>

        <Border Grid.Row="3" CornerRadius="8" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <DataGrid x:Name="FilesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="0"
                      Margin="4">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="140" />
                    <DataGridTextColumn Header="Length (bytes)" Binding="{Binding DataLength}" Width="160" />
                    <DataGridTextColumn Header="Blocks" Binding="{Binding BlockCount}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
