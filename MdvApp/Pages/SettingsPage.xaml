<Page x:Class="MdvApp.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="980"
      Title="Settings">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8,24,24">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
            <ui:TextBlock Text="Settings" FontTypography="Title" Margin="0,0,0,16" />

            <ui:CardControl Margin="0,0,0,8" Icon="{ui:SymbolIcon DarkTheme24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock Text="Dark theme" FontTypography="BodyStrong" />
                        <ui:TextBlock Text="Toggle the Fluent light / dark appearance"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="ThemeToggle" Checked="OnThemeToggled" Unchecked="OnThemeToggled" />
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,8" Icon="{ui:SymbolIcon Grid24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock Text="Sector allocation strategy" FontTypography="BodyStrong" />
                        <ui:TextBlock Text="How new file blocks are placed when writing an image"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox x:Name="AllocationCombo" Width="160" SelectedIndex="0">
                    <ComboBoxItem Content="Sequential" />
                    <ComboBoxItem Content="Spaced" />
                    <ComboBoxItem Content="Random" />
                </ComboBox>
            </ui:CardControl>

            <ui:CardControl Icon="{ui:SymbolIcon Info24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock Text="About" FontTypography="BodyStrong" />
                        <ui:TextBlock x:Name="AboutText"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>
        </StackPanel>
    </ScrollViewer>
</Page>
