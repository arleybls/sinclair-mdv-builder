<Page x:Class="MdvApp.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="980"
      Title="Settings">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8,24,24">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
            <ui:TextBlock Text="Settings" FontTypography="Title" Margin="0,0,0,16" />

            <ui:CardControl Margin="0,0,0,8" Icon="{ui:SymbolIcon DarkTheme24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock Text="Dark theme" FontTypography="BodyStrong" />
                        <ui:TextBlock Text="Toggle the Fluent light / dark appearance"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="ThemeToggle" Checked="OnThemeToggled" Unchecked="OnThemeToggled" />
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,8" Icon="{ui:SymbolIcon Grid24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock Text="Sector allocation strategy" FontTypography="BodyStrong" />
                        <ui:TextBlock Text="How new file blocks are placed when writing an image"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Info24" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" Cursor="Help" ToolTipService.ShowDuration="20000">
                        <ui:SymbolIcon.ToolTip>
                            <ToolTip MaxWidth="360">
                                <TextBlock TextWrapping="Wrap"
                                           Text="Sector allocation strategy:&#10;Sequential — fill consecutive sectors from the start (contiguous, simplest).&#10;Spaced — step back 13 sectors each block to spread files out.&#10;Random — scatter blocks across random free sectors." />
                            </ToolTip>
                        </ui:SymbolIcon.ToolTip>
                    </ui:SymbolIcon>
                    <ComboBox x:Name="AllocationCombo" Width="160" SelectionChanged="OnAllocationChanged">
                        <ComboBoxItem Content="Sequential" />
                        <ComboBoxItem Content="Spaced" />
                        <ComboBoxItem Content="Random" />
                    </ComboBox>
                </StackPanel>
            </ui:CardControl>

            <ui:CardControl Icon="{ui:SymbolIcon Info24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock Text="About" FontTypography="BodyStrong" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <ui:TextBlock x:Name="AboutText" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,2,0,0" />
                        <ui:TextBlock Text="© 2026 Arley Silveira — MIT License"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,2,0,0" />

                        <ui:TextBlock Text="Third-party components" FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,12,0,2" />
                        <ui:TextBlock TextWrapping="Wrap"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="WPF-UI — MIT License, © lepo.co (lepoco)&#10;SharpZipLib — MIT License, © ICSharpCode&#10;Fluent System Icons — MIT License, © Microsoft Corporation&#10;.NET / WPF — © Microsoft Corporation" />
                        <ui:TextBlock Margin="0,4,0,0" TextWrapping="Wrap"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="MDV/DMP/MPD format reference: " /><Hyperlink
                                NavigateUri="https://github.com/gusmanb/micropicodrive"
                                RequestNavigate="OnRequestNavigate">gusmanb/micropicodrive</Hyperlink>
                        </ui:TextBlock>
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>
        </StackPanel>
    </ScrollViewer>
</Page>
